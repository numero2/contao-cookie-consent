<?xml version="1.0"?>
<xliff version="1.1">
<file source-language="en" target-language="sv">
<body>
    <!-- LEGENDS -->
    <trans-unit id="tl_cc_tag.common_legend">
        <source>General</source>
        <target>Allmän</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.description_legend">
        <source>Group Description</source>
        <target>Gruppbeskrivning</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.tag_legend">
        <source>Tag Settings</source>
        <target>Tagginställningar</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.config_legend">
        <source>Tag Configuration</source>
        <target>Taggkonfiguration</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.expert_legend">
        <source>Expert Settings</source>
        <target>Expertinställningar</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.publish_legend">
        <source>Publication</source>
        <target>Offentliggörande</target>
    </trans-unit>
    <!-- FIELDS -->
    <trans-unit id="tl_cc_tag.type.0">
        <source>Tag Type</source>
        <target>Taggtyp</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.type.1">
        <source>Please select the type of tag.</source>
        <target>Välj typ av tagg.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.name.0">
        <source>Name</source>
        <target>Namn</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.name.1">
        <source>Please give this tag a name.</source>
        <target>Vänligen ge denna tag ett namn.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.root.0">
        <source>Set for...</source>
        <target>Ställ in för...</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.root.1">
        <source>Determines whether the name and description apply to all page roots or only to a specific page.</source>
        <target>Bestämmer om namnet och beskrivningen gäller för alla sidrötter eller bara för en specifik sida.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.description.0">
        <source>Description</source>
        <target>Beskrivning</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.description.1">
        <source>This description is displayed to the user as an explanation.</source>
        <target>Denna beskrivning visas för användaren som en förklaring.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.html.0">
        <source>HTML Code</source>
        <target>HTML-kod</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.section.0">
        <source>Deliver in</source>
        <target>Leverera in</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.section.1">
        <source>Please select in which area the tag should be delivered.</source>
        <target>Välj i vilket område taggen ska levereras.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.fallbackTpl.0">
        <source>Fallback Template</source>
        <target>Reservmall</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.fallbackTpl.1">
        <source>Here you can specify a "Fallback Template" that will be displayed to the user if the tag is not confirmed.</source>
        <target>Här kan du ange en "Fallback Template" som kommer att visas för användaren om taggen inte bekräftas.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.fallback_text.0">
        <source>Fallback Text</source>
        <target>Reservtext</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.fallback_text.1">
        <source>Here you can specify a fallback text that will be displayed to the user if the tag is not confirmed.</source>
        <target>Här kan du ange en reservtext som kommer att visas för användaren om taggen inte bekräftas.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.customTpl.0">
        <source>Custom Template</source>
        <target>Anpassad mall</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.customTpl.1">
        <source>Here you can override the default template.</source>
        <target>Här kan du åsidosätta standardmallen.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.pages_scope.0">
        <source>Page Scope</source>
        <target>Sidomfång</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.pages_scope.1">
        <source>Scope of the selected pages</source>
        <target>Omfattning av de valda sidorna</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.pages.0">
        <source>Pages</source>
        <target>Sidor</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.pages.1">
        <source>Please select on which pages the page scope should be applied.</source>
        <target>Välj på vilka sidor sidomfattningen ska tillämpas.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.pages_root.0">
        <source>Pages</source>
        <target>Sidor</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.pages_root.1">
        <source>Please select on which page roots this element should be displayed as requiring consent. If nothing is selected, it is assumed that this element is used on multiple page roots.</source>
        <target>Vänligen välj på vilka sidorötter detta element ska visas eftersom det kräver samtycke. Om inget är markerat antas det att detta element används på flera sidrötter.</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.active.0">
        <source>Active?</source>
        <target>Aktiv?</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.active.1">
        <source>Activate this tag?</source>
        <target>Aktivera den här taggen?</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.enable_on_cookie_accept.0">
        <source>Opt-In / EU-Privacy Compliant</source>
        <target>Opt-in / EU-integritetskompatibel</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.enable_on_cookie_accept.1">
        <source>If enabled, this tag will only be delivered if cookies are accepted, otherwise always.</source>
        <target>Om den är aktiverad kommer denna tagg endast att levereras om cookies accepteras, annars alltid.</target>
    </trans-unit>
    <!-- OPTIONS -->
    <trans-unit id="tl_cc_tag.types.default">
        <source>-</source>
        <target>-</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.group">
        <source>Group</source>
        <target>Grupp</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.session">
        <source>Session Cookie</source>
        <target>Sessionskaka</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.html">
        <source>HTML</source>
        <target>HTML</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.google_analytics">
        <source>Google Analytics</source>
        <target>Google Analytics</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.google_tag_manager">
        <source>Google Tag Manager</source>
        <target>Google Tag Manager</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.facebook_pixel">
        <source>Facebook Pixel</source>
        <target>Facebook Pixel</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.matomo">
        <source>Matomo</source>
        <target>Matomo</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.types.content_module_element">
        <source>Content Element / Frontend Module</source>
        <target>Innehållselement / Frontend-modul</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.sections.head">
        <source>Head Section</source>
        <target>Huvudsektion</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.sections.body">
        <source>Body Section</source>
        <target>Kroppssektion</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.page_scopes.none">
        <source>No automatic delivery</source>
        <target>Ingen automatisk leverans</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.page_scopes.current_page">
        <source>Only selected pages</source>
        <target>Endast valda sidor</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.page_scopes.current_and_direct_children">
        <source>Selected pages and direct subpages</source>
        <target>Utvalda sidor och direkta undersidor</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.page_scopes.current_and_all_children">
        <source>Selected pages and all subpages</source>
        <target>Valda sidor och alla undersidor</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.roots.default">
        <source>all pages</source>
        <target>alla sidor</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.roots.default_initial">
        <source>all pages (save to select more page roots)</source>
        <target>alla sidor (spara för att välja fler sidrötter)</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.roots.specific">
        <source>only for the page "%s"</source>
        <target>endast för sidan "%s"</target>
    </trans-unit>
    <!-- DEFAULTS -->
    <trans-unit id="tl_cc_tag.default.0.name">
        <source>Necessary</source>
        <target>Nödvändig</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.0.description">
        <source><![CDATA[<p>Tools that enable essential services and functions, including identity verification, service continuity and site security. This option cannot be declined.</p>]]></source>
        <target><![CDATA[<p>Verktyg som möjliggör viktiga tjänster och funktioner, inklusive identitetsverifiering, tjänstekontinuitet och platssäkerhet. Det här alternativet kan inte avvisas.</p>]]></target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.1.name">
        <source>Statistics</source>
        <target>Statistik</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.1.description">
        <source><![CDATA[<p>We collect anonymous data about the use and functionality of our site. We use these insights to improve our products, services and user experience.</p>]]></source>
        <target><![CDATA[<p>Vi samlar in anonym information om användningen och funktionaliteten av vår webbplats. Vi använder dessa insikter för att förbättra våra produkter, tjänster och användarupplevelse.</p>]]></target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.2.name">
        <source>Marketing</source>
        <target>Marknadsföring</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.2.description">
        <source><![CDATA[<p>Anonymous information we collect to be able to recommend useful products and services to you.</p>]]></source>
        <target><![CDATA[<p>Anonym information vi samlar in för att kunna rekommendera användbara produkter och tjänster till dig.</p>]]></target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.3.name">
        <source>Third-party Content</source>
        <target>Innehåll från tredje part</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.3.description">
        <source><![CDATA[<p>Content from third parties such as videos from YouTube or maps from Google Maps.</p>]]></source>
        <target><![CDATA[<p>Innehåll från tredje part som videor från YouTube eller kartor från Google Maps.</p>]]></target>
    </trans-unit>
</body>
