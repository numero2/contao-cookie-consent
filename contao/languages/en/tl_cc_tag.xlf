    <trans-unit id="tl_cc_tag.default.1.name">
        <target>Statistik</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.1.description">
        <target><![CDATA[<p>]]>Wir sammeln anonyme Daten über Nutzung und -Funktionalität unserer Seite. Wir nutzen diese Erkenntnisse, um unsere Produkte, Dienstleistungen und das Benutzererlebnis zu verbessern.<![CDATA[</p>]]></target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.2.name">
        <target>Werbung</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.2.description">
        <target><![CDATA[<p>]]>Anonyme Informationen, die wir sammeln, um Ihnen nützliche Produkte und Dienstleistungen empfehlen zu können.<![CDATA[</p>]]></target>
    </trans-unit>
