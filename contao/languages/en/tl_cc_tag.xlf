    <trans-unit id="tl_cc_tag.default.0.name">
        <target>Notwendig</target>
    </trans-unit>
    <trans-unit id="tl_cc_tag.default.0.description">
        <target><![CDATA[<p>]]>Tools, die wesentliche Services und Funktionen ermöglichen, einschließlich Identitätsprüfung, Servicekontinuität und Standortsicherheit. Diese Option kann nicht abgelehnt werden.<![CDATA[</p>]]></target>
