<?xml version="1.0"?>
<xliff version="1.1">
<file>
<body>
    <!-- LEGENDS -->
    <trans-unit id="tl_module.cc_tag_visibility_legend">
        <target>Cookie Consent: Opt-In/ EU-Privacy</target>
    </trans-unit>
    <!-- FIELDS -->
    <trans-unit id="tl_module.cc_override_labels.0">
        <target>Beschriftung ändern</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_override_labels.1">
        <target>Wollen Sie die Texte im Cookie Consent selbst festlegen.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_accept_label.0">
        <target>Beschriftung "Bestätigen"</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_accept_label.1">
        <target>Dieser Text wird auf dem Button "Bestätigen" angezeigt.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_accept_all_label.0">
        <target>Beschriftung "Alle akzeptieren"</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_accept_all_label.1">
        <target>Wird hier ein Text hinterlegt wird ein zusätzlicher Button angezeigt mit dem es möglich ist alle Gruppen auf einmal zu bestätigen.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_text.0">
        <target>Inhalt</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_text.1">
        <target>Dieser Inhalt wird innerhalb des Cookie Consents angezeigt.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_exclude_pages.0">
        <target>Auf diesen Seiten keinen Cookie Consent zeigen</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_exclude_pages.1">
        <target>Cookie Consent wird nicht gezeigt. Die Seite ist nutzbar. Es wird kein Cookie auf dieser Seite gesetzt. Sinnvoll beispielsweise für die Datenschutzerklärung, damit diese immer ganz sichtbar und lesbar ist.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_cookie_lifetime.0">
        <target>Dauer der Einwilligung</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_cookie_lifetime.1">
        <target>Wählen Sie aus wie lange die Einwilligung des Besuchers in Form eines Cookies gespeichert werden soll.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_accept_subdomains.0">
        <target>Einwilligung auf Subdomains übernehmen</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_accept_subdomains.1">
        <target>Falls aktiviert wird die getroffene Auswahl automatisch für alle Subdomains übernommen.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_hide_copyright.0">
        <target>Copyright-Hinweis ausblenden?</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_hide_copyright.1">
        <target>Blendet den Hinweis auf die Bereitsstellung des Cookie-Consents von numero2 aus.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag_visibility.0">
        <target>Nur mit expliziter Zustimmung anzeigen</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag_visibility.1">
        <target>Das Frontend-Modul nur anzeigen wenn der Nutzer explizit seine Zustimmung für das entsprechende "Inhaltselement / Frontend-Modul"-Tag gegeben hat.</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag.0">
        <target>Inhaltselement / Frontend-Modul-Tag</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag.1">
        <target>Wählen Sie aus welchem Tag zugestimmt werden muss um das Frontend-Modul anzuzeigen.</target>
    </trans-unit>
    <!-- OPITONS -->
    <trans-unit id="tl_module.cc_tag_cookie_lifetime_units.days">
        <target>Tag(e)</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag_cookie_lifetime_units.weeks">
        <target>Woche(n)</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag_cookie_lifetime_units.months">
        <target>Monat(e)</target>
    </trans-unit>
    <trans-unit id="tl_module.cc_tag_cookie_lifetime_units.years">
        <target>Jahr(e)</target>
    </trans-unit>
</body>
</file>
