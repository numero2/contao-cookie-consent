{% extends '@Contao/styles/cc_default.html.twig' %}

{% block styles %}

.sr-only {
	position: absolute;
	width: 1px;
	height: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

dialog {
	all: unset;
	display: flex;
	align-items: center;
	justify-content: center;
	position: fixed;
	inset: 0;
	z-index: 9999;
	width: 100%;
	height: 100%;
	box-sizing: border-box;
	padding: 1rem;
	pointer-events: none;

    &[open] {
        pointer-events: auto;
    }

    &:not([open]) {
        display: none;
    }

    &::backdrop {
        display: none;
    }
}

.backdrop {
	position: fixed;
	inset: 0;
	background: rgba(0, 0, 0, .45);
	backdrop-filter: blur(3px);
	-webkit-backdrop-filter: blur(3px);
	animation: cc-fade var(--cc-speed) ease forwards;
}

.panel {

    position: relative;
	z-index: 1;
	background: var(--cc-bg);
	border-radius: var(--cc-radius);
	box-shadow: var(--cc-shadow);
	width: min(700px, 90vw - 50px);
	max-height: calc(100svh - 2rem);
	overflow-y: auto;
	overscroll-behavior: contain;
	animation: cc-up var(--cc-speed) cubic-bezier(.34, 1.56, .64, 1) forwards;
	scrollbar-width: thin;
	scrollbar-color: var(--cc-border) transparent;

    &::-webkit-scrollbar {
        width: 4px;
    }

    &::-webkit-scrollbar-thumb {
        background: var(--cc-border);
        border-radius: 4px;
    }
}

form {

    padding: 1.75rem 1.75rem 1.5rem;
	display: flex;
	flex-direction: column;
	gap: 1.25rem;

    &.loading {
        pointer-events: none;
    }
}

.disclaimer {

    * {
        font-family: var(--cc-font);
        color: var(--cc-text);
    }

    p {
        margin: 0 0 .5rem;
        font-size: .875rem;
        line-height: 1.6;
        color: var(--cc-text-muted);
    }

    p:nth-child(1) strong {
        font-size: 1.0625rem;
        font-weight: 700;
        color: var(--cc-text);
        display: block;
        margin-bottom: .25rem;
        font-family: var(--cc-font-heading);
        letter-spacing: -.01em;
    }

    a {
        color: var(--cc-accent);
        text-underline-offset: 2px;

        &:hover {
            color: var(--cc-accent-hover);
        }
    }
}

.categories {

    all: unset;
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	gap: .625rem;
}

.category {

    flex: 1 1 0;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius-sm);
    overflow: hidden;
    transition: border-color var(--cc-speed);

    &:focus-within {
        border-color: var(--cc-accent);
    }

    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        padding: .75rem 1rem;
        background: var(--cc-surface);
    }

    .title {
        font-family: var(--cc-font);
        font-size: .875rem;
        font-weight: 600;
        color: var(--cc-text);
        flex: 1;
    }

    .badge {
        font-size: .6875rem;
        font-family: var(--cc-font);
        font-weight: 500;
        color: var(--cc-accent);
        background: var(--cc-accent-light);
        padding: .25em .75em;
        border-radius: 2em;
        white-space: nowrap;
        height: 18px;
        display: inline-flex;
        align-items: center;
    }

    .body {

        flex: 1;
        padding: .75rem 1rem;
        border-top: 1px solid var(--cc-border);

        p {
            margin: 0;
            font-size: 0.75rem;
            font-family: var(--cc-font);
            line-height: 1.55;
            color: var(--cc-text-muted);
        }
    }
}

.toggle {

    position: relative;
	display: inline-flex;
	align-items: center;
	cursor: pointer;
	flex-shrink: 0;

    input {

        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;

        &:checked ~ .track {
            background: var(--cc-toggle-on);
        }

        &:checked ~ .track .thumb {
            transform: translateX(18px);
        }

        &:focus-visible ~ .track {
            outline: 2px solid var(--cc-accent);
            outline-offset: 2px;
        }
    }

    .track {

        display: flex;
        align-items: center;
        width: 40px;
        height: 22px;
        background: var(--cc-toggle-off);
        border-radius: 99px;
        padding: 2px;
        transition: background var(--cc-speed);
        box-sizing: border-box;

        .thumb {

            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--cc-toggle-thumb);
            box-shadow: 0 1px 3px rgba(0, 0, 0, .2);
            transition: transform var(--cc-speed) cubic-bezier(.34, 1.56, .64, 1);
            flex-shrink: 0;
        }
    }
}

.actions {
	display: flex;
	gap: .625rem;
}

.btn {

    all: unset;
	cursor: pointer;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	border-radius: var(--cc-radius-sm);
	font-family: var(--cc-font);
	font-size: .875rem;
	font-weight: 600;
	padding: .625rem 1.125rem;
	transition: background var(--cc-speed), color var(--cc-speed),
    box-shadow var(--cc-speed), transform .1s;
	line-height: 1;
	white-space: nowrap;
	user-select: none;
	-webkit-tap-highlight-color: transparent;
	flex: 1;
    position: relative;

    --text: currentColor;

    &:focus-visible {
        outline: 2px solid var(--cc-accent);
        outline-offset: 2px;
    }

    &:active {
        transform: scale(.97);
    }

    &.confirm {

        background: transparent;
        color: var(--cc-text);
        border: 1.5px solid var(--cc-btn-ghost-border);

        &:hover, &:focus {
            background: var(--cc-surface);
            border-color: var(--cc-text-muted);
        }
    }

    &.all {

        background: var(--cc-accent);
        color: var(--cc-accent-text);
        border: 1.5px solid var(--cc-accent);

        &:hover, &:focus {
            background: var(--cc-accent-hover);
            border-color: var(--cc-accent-hover);
        }

        &.loading {
            --text: var(--cc-accent-text);
        }
    }

    &[disabled] {
        pointer-events: none;
        opacity: 0.5;
    }

    svg {

        position: absolute;
        top: 50%;
        left: 50%;

        transform: translateX(-50%) translateY(-50%);

        height: 2em;

        [fill] { fill: var(--text); }
        [stroke] { stroke: var(--text); }
    }

    &:not(.loading) svg {
        display: none;
    }

    &.loading {
        --text: var(--cc-text);
        color: rgba(0,0,0,0);
        background: url(var(--cc-loading)) no-repeat scroll 50% 50%;
    }
}

.copyright {

    font-family: var(--cc-font);
    font-size: .625rem;
    text-align: center;
    color: var(--cc-text-muted);
    opacity: .5;

    a {
        color: inherit;

        &:hover, &:focus {
            color: var(--cc-accent-hover);
        }
    }
}

@keyframes cc-fade {
	from {
		opacity: 0;
	}

	to {
		opacity: 1;
	}
}

@keyframes cc-up {
	from {
		opacity: 0;
		transform: translateY(16px) scale(.98);
	}

	to {
		opacity: 1;
		transform: translateY(0) scale(1);
	}
}

@media( prefers-reduced-motion: reduce ) {

	.backdrop,
	.panel {
		animation: cc-fade .1s linear forwards;
	}

	.toggle__thumb,
	.toggle__track,
	.btn {
		transition: none;
	}
}

@media( max-width: 480px ) {

	dialog {
		padding: 0;
		align-items: flex-end;
	}

	.panel {
		width: 100%;
		border-bottom-left-radius: 0;
		border-bottom-right-radius: 0;
		max-height: 90svh;
		animation-name: cc-mobile;
	}

	.categories {
		flex-direction: column;
	}

	.category {
		flex-basis: auto;
	}

	.actions {
		flex-direction: column-reverse;
	}
}

@keyframes cc-mobile {
	from {
		opacity: 0;
		transform: translateY(100%);
	}

	to {
		opacity: 1;
		transform: translateY(0);
	}
}

{% endblock %}